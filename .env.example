ADMIN_USERNAME=mcassyblasty
POSTGRES_DB=grishcord
POSTGRES_USER=grishcord
POSTGRES_PASSWORD=change_me
# For docker compose, DB host must be the service name `postgres`, not localhost.
DATABASE_URL=postgres://grishcord:change_me@postgres:5432/grishcord
JWT_SECRET=use_a_random_secret_with_at_least_32_chars
PUBLIC_BASE_URL=https://grishcord.countgrishnackh.com
# Comma-separated trusted frontend origins for credentialed API requests.
CORS_ORIGINS=https://grishcord.countgrishnackh.com
# Hostname only (no scheme/path). Must resolve to this server for automatic HTTPS.
CADDY_SITE_ADDRESS=grishcord.countgrishnackh.com
COOKIE_SECURE=true
RETENTION_THRESHOLD_PCT=90
RETENTION_INTERVAL_MS=120000
MAX_UPLOAD_BYTES=104857600
# Optional override; by default backend reads /app/VERSION in Docker.
APP_VERSION=


# Bot gating (optional)
BOT_ENABLE_DMS=true
BOT_ENABLE_CHANNELS=true
# Optional comma-separated channel allowlist for bot channel replies.
BOT_ALLOWED_CHANNEL_IDS=
BOT_CONTEXT_MAX_MESSAGES=10
# Reply with a short fallback when generation fails (timeout/error/empty output).
BOT_REPLY_ON_ERROR=false
